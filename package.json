{
  "name": "ghostpres",
  "version": "0.0.1",
  "description": "MongoDB-shaped aggregation pipelines for Postgres jsonb. The inversion of Postgres.",
  "type": "module",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "Douglas Jordan",
  "keywords": [
    "postgres",
    "postgresql",
    "jsonb",
    "mongodb",
    "aggregation",
    "pipeline",
    "query-builder",
    "drizzle",
    "bun",
    "typescript"
  ],
  "scripts": {
    "test": "bun test",
    "test:integration": "bun test test/integration",
    "typecheck": "tsc --noEmit",
    "demo": "bun examples/run.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "postgres": "^3.4.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
